#!/usr/bin/env python3
"""
duplex-print: manual duplex print helper for the Canon iP100 (or any one-sided printer).

Usage:
    duplex-print <pdf-file> [-P printer]

Workflow:
    1. Splits the PDF into odd pages (1, 3, 5, ...) and even pages reversed
       (..., 6, 4, 2).
    2. Sends odd pages to the printer.
    3. Pauses with a prompt: "Flip the stack so blank backs are up (top sheet
       becomes the bottom-printed page). Press Enter when ready."
    4. Sends even pages reversed; printer prints them on the backs.

After both jobs the output stack is in correct page order 1, 2, 3, 4, ...

Tuned for printers that output face-up (Canon iP100 portable inkjet). For
printers that output face-down, pass --no-reverse-even.
"""

import argparse
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

try:
    import fitz  # PyMuPDF
except ImportError:
    sys.stderr.write("PyMuPDF not installed. Run: pip install --user pymupdf\n")
    sys.exit(1)


def split_pdf(src: Path, tmpdir: Path, reverse_even: bool):
    """Return (odd_pdf_path, even_pdf_path, page_count).

    If the source has an odd number of pages, a blank page is inserted at
    the position that will land on the back of the last sheet (so the last
    page comes out with a blank back as expected).
    """
    doc = fitz.open(str(src))
    n = doc.page_count
    odd_count_source = (n % 2 == 1)

    # Reference page size from the first page (for the synthesized blank).
    page0 = doc[0]
    blank_w, blank_h = page0.rect.width, page0.rect.height

    odd_doc = fitz.open()
    even_doc = fitz.open()

    for i in range(0, n, 2):  # PDF pages 1, 3, 5 ...
        odd_doc.insert_pdf(doc, from_page=i, to_page=i)

    even_indices = list(range(1, n, 2))
    if reverse_even:
        even_indices.reverse()
    for i in even_indices:
        even_doc.insert_pdf(doc, from_page=i, to_page=i)

    # If the source had an odd count, the very last sheet (printed last in
    # the odd pass) ends up on top after the flip. Add a blank as the FIRST
    # page of the even-pass PDF so the blank lands on that last sheet's back,
    # not a real even page.
    if odd_count_source:
        if reverse_even:
            # Reversed list already covers evens; prepend a blank at the front
            # so it prints first.
            even_doc.insert_page(0, width=blank_w, height=blank_h)
        else:
            # Forward order: the LAST sheet to print on (the highest odd page)
            # is the last one fed. With forward even, the LAST even-pdf page
            # lands on it - so APPEND a blank at the end.
            even_doc.insert_page(-1, width=blank_w, height=blank_h)

    odd_path = tmpdir / f"{src.stem}_odd.pdf"
    even_path = tmpdir / f"{src.stem}_even.pdf"
    odd_doc.save(str(odd_path))
    even_doc.save(str(even_path))
    return odd_path, even_path, n


def lp_submit(pdf_path: Path, printer: str | None) -> str:
    cmd = ["lp"]
    if printer:
        cmd += ["-d", printer]
    cmd.append(str(pdf_path))
    r = subprocess.run(cmd, capture_output=True, text=True, check=True)
    return r.stdout.strip()


def wait_for_queue(printer: str | None):
    """Block until the printer queue is empty."""
    while True:
        cmd = ["lpstat", "-o"]
        if printer:
            cmd = ["lpstat", "-o", printer]
        out = subprocess.run(cmd, capture_output=True, text=True).stdout.strip()
        if not out:
            return
        # Show what's still in the queue.
        print(f"  waiting... ({out.splitlines()[0]})", end="\r")
        import time
        time.sleep(1)


def main():
    ap = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("pdf", help="PDF file to print")
    ap.add_argument("-P", "--printer", help="Printer name (default: system default)")
    ap.add_argument("--no-reverse-even", action="store_true",
                    help="Print even pages in forward order (2,4,6,...). Use this if "
                         "your printer outputs face-down. Default reverses them, which "
                         "is correct for face-up output (Canon iP100).")
    ap.add_argument("--no-prompt", action="store_true",
                    help="Skip the flip-the-stack prompt (use only after queue is empty)")
    args = ap.parse_args()

    src = Path(args.pdf).expanduser().resolve()
    if not src.exists():
        sys.stderr.write(f"file not found: {src}\n")
        sys.exit(1)

    tmpdir = Path(tempfile.mkdtemp(prefix="duplex_"))
    try:
        odd_pdf, even_pdf, n = split_pdf(src, tmpdir, reverse_even=not args.no_reverse_even)
        odd_pages = list(range(1, n + 1, 2))
        even_pages = list(range(2, n + 1, 2))
        if not args.no_reverse_even:
            even_pages.reverse()

        print(f"Source: {src.name}  ({n} pages)")
        print(f"  odd pass:  pages {odd_pages}")
        print(f"  even pass: pages {even_pages}{' (reversed for face-up output)' if not args.no_reverse_even else ''}")
        print()

        # Step 1: print odd pages
        print(f"[1/2] Sending odd pages to printer...")
        print("  " + lp_submit(odd_pdf, args.printer))

        if not args.no_prompt:
            print()
            print("Wait for the printer to finish, then:")
            print("  1. Take the stack out of the output tray.")
            print("  2. Flip it like a pancake so the printed sides are face DOWN")
            print("     and the blank backs are face UP.")
            print("  3. Put it back into the input tray (same edge facing the printer).")
            input("\nPress Enter when the stack is loaded and ready...")

        # Step 2: print even pages
        print(f"\n[2/2] Sending even pages to printer...")
        print("  " + lp_submit(even_pdf, args.printer))
        print("\nDone. Output should be in order: " + ", ".join(str(i) for i in range(1, n + 1)))

    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)


if __name__ == "__main__":
    main()
